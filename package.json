{
  "name": "neuro-academy-v2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "dotenv": "^16.0.0",
    "telegraf": "^4.16.3"
  },
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web-miniapp",
    "dev:admin": "npm run dev -w apps/admin",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "db:generate": "npm run generate -w packages/database",
    "db:migrate": "npm run migrate -w packages/database",
    "db:seed": "npm run seed -w packages/database"
  }
}
